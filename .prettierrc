{
	"printWidth": 88,
	"singleQuote": false,
	"semi": true,
	"trailingComma": "es5",
  "overrides": [
    {
      "files": ["**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ],
	"plugins": [
		"@ianvs/prettier-plugin-sort-imports",
		"prettier-plugin-packagejson"
	],
	"importOrder": [
		"<BUILTIN_MODULES>",
		"<THIRD_PARTY_MODULES>",
		"^[.]{2}$",
		"^[.]{2}/",
		"^[.]/(?!index)",
		"^[.]$",
		"^[.]/index$",
		"<TYPES>"
	],
	"importOrderTypeScriptVersion": "5.8.3",
	"importOrderParserPlugins": [
		"typescript",
		"jsx",
		"decorators",
		"explicitResourceManagement"
	]
}
